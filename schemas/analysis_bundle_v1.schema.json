{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalysisBundle",
  "description": "Comprehensive and final analysis output from the ME Engine Core.",
  "type": "object",
  "required": ["metadata", "hits", "aggregates", "scores", "drift"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["source_file", "analysis_timestamp", "schema_version"],
      "properties": {
        "source_file": { "type": "string" },
        "analysis_timestamp": { "type": "string", "format": "date-time" },
        "schema_version": { "type": "string", "const": "analysis_bundle_v1" }
      }
    },
    "hits": {
      "type": "array",
      "description": "Detected marker hits from the full analysis pipeline.",
      "items": {
        "type": "object",
        "required": ["marker_id", "message_id", "score"],
        "properties": {
          "marker_id": { "type": "string" },
          "message_id": {
            "type": "string",
            "description": "ID of the message where the hit occurred."
          },
          "score": { "type": "number" },
          "details": { "type": "object" }
        }
      }
    },
    "aggregates": {
      "type": "object",
      "description": "Aggregated data for different markers or categories."
    },
    "scores": {
      "type": "object",
      "description": "Final calculated scores for the entire conversation."
    },
    "drift": {
      "type": "object",
      "description": "Data for rendering drift curves over time.",
      "required": ["timestamps", "values"],
      "properties": {
        "timestamps": { "type": "array", "items": { "type": "number" } },
        "values": { "type": "array", "items": { "type": "number" } }
      }
    }
  }
}
